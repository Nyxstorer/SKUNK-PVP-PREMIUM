-- ==================== FUNÇÕES AUXILIARES ====================
local function isAlive(player)
    if not player or not player.Character then return false end
    local hum = player.Character:FindFirstChild("Humanoid")
    return hum and hum.Health > 0
end

local function getAimPart(char)
    if not char then return nil end
    local part = char:FindFirstChild(AimPart)
    if not part then part = char:FindFirstChild("Head") end
    return part
end

local function w2s(pos)
    local v, onScreen = Camera:WorldToViewportPoint(pos)
    return Vector2.new(v.X, v.Y), onScreen, v.Z
end

local function createLine()
    local line = Drawing.new("Line")
    line.Thickness = 2
    line.Transparency = 1
    line.Visible = false
    return line
end

local function hideAll(connections)
    for _, data in pairs(connections) do
        if type(data) == "table" then
            for _, obj in pairs(data) do pcall(function() obj.Visible = false end) end
        else
            pcall(function() data.Visible = false end)
        end
    end
end

-- ==================== SKELETON ESP ====================
local function updateSkeleton()
    hideAll(SkeletonConnections)
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not isAlive(player) then continue end
        local char = player.Character
        local root = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        if not root or not head then continue end
        local _, onScreen, dist = w2s(root.Position)
        if not onScreen or dist > MaxDistanceToShow then continue end
        if not SkeletonConnections[player] then
            SkeletonConnections[player] = {
                HeadToTorso = createLine(),
                TorsoToLeftArm = createLine(),
                TorsoToRightArm = createLine(),
                TorsoToLeftLeg = createLine(),
                TorsoToRightLeg = createLine(),
                LeftArm = createLine(),
                RightArm = createLine(),
                LeftLeg = createLine(),
                RightLeg = createLine()
            }
        end
        local sk = SkeletonConnections[player]
        local color = Color3.fromRGB(0, 255, 0)
        local function connect(a, b, line)
            if a and b then
                local posA = w2s(a.Position)
                local posB = w2s(b.Position)
                line.From = posA
                line.To = posB
                line.Color = color
                line.Visible = true
            end
        end
        local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
        local leftArm = char:FindFirstChild("LeftUpperArm") or char:FindFirstChild("Left Arm")
        local rightArm = char:FindFirstChild("RightUpperArm") or char:FindFirstChild("Right Arm")
        local leftLeg = char:FindFirstChild("LeftUpperLeg") or char:FindFirstChild("Left Leg")
        local rightLeg = char:FindFirstChild("RightUpperLeg") or char:FindFirstChild("Right Leg")
        connect(head, torso, sk.HeadToTorso)
        connect(torso, leftArm, sk.TorsoToLeftArm)
        connect(torso, rightArm, sk.TorsoToRightArm)
        connect(torso, leftLeg, sk.TorsoToLeftLeg)
        connect(torso, rightLeg, sk.TorsoToRightLeg)
        if leftArm and char:FindFirstChild("LeftLowerArm") then connect(leftArm, char.LeftLowerArm, sk.LeftArm) end
        if rightArm and char:FindFirstChild("RightLowerArm") then connect(rightArm, char.RightLowerArm, sk.RightArm) end
        if leftLeg and char:FindFirstChild("LeftLowerLeg") then connect(leftLeg, char.LeftLowerLeg, sk.LeftLeg) end
        if rightLeg and char:FindFirstChild("RightLowerLeg") then connect(rightLeg, char.RightLowerLeg, sk.RightLeg) end
    end
end

-- ==================== TRACERS ====================
local function updateTracers()
    hideAll(TracerLines)
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not isAlive(player) then continue end
        local char = player.Character
        local head = char:FindFirstChild("Head")
        if not head then continue end
        local headPos, onScreen, dist = w2s(head.Position)
        if not onScreen or dist > MaxDistanceToShow then continue end
        if not TracerLines[player] then
            TracerLines[player] = createLine()
            TracerLines[player].Color = TracerColor
        end
        local line = TracerLines[player]
        local startY = Camera.ViewportSize.Y / 2
        if TracerPosition == "Linha Alto" then startY = 0
        elseif TracerPosition == "Linha Baixo" then startY = Camera.ViewportSize.Y end
        line.From = Vector2.new(Camera.ViewportSize.X / 2, startY)
        line.To = headPos
        line.Visible = true
    end
end

-- ==================== BOX ESP ====================
local function updateBoxESP()
    hideAll(BoxConnections)
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not isAlive(player) then continue end
        local char = player.Character
        local head = char:FindFirstChild("Head")
        local hum = char:FindFirstChild("Humanoid")
        if not head or not hum then continue end
        local headPos, onScreen, dist = w2s(head.Position)
        if not onScreen or dist > MaxDistanceToShow then continue end
        if not BoxConnections[player] then
            BoxConnections[player] = {
                TL = createLine(), TR = createLine(), BL = createLine(), BR = createLine(),
                HealthBG = createLine(), Health = createLine()
            }
        end
        local data = BoxConnections[player]
        local size = 1600 / dist
        local x = headPos.X - size/2
        local y = headPos.Y - size/1.8
        local w = size
        local h = size * 1.85
        for _, line in pairs({data.TL, data.TR, data.BL, data.BR}) do
            line.Color = Color3.fromRGB(255, 0, 0)
            line.Visible = true
        end
        data.TL.From = Vector2.new(x, y); data.TL.To = Vector2.new(x+w, y)
        data.TR.From = Vector2.new(x+w, y); data.TR.To = Vector2.new(x+w, y+h)
        data.BL.From = Vector2.new(x, y+h); data.BL.To = Vector2.new(x+w, y+h)
        data.BR.From = Vector2.new(x, y); data.BR.To = Vector2.new(x, y+h)
        local hp = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
        data.HealthBG.From = Vector2.new(x-6, y)
        data.HealthBG.To = Vector2.new(x-6, y+h)
        data.HealthBG.Color = Color3.fromRGB(30,30,30)
        data.HealthBG.Visible = true
        if hp > 0 then
            local healthY = y + h * (1 - hp)
            local barColor = (hp > 0.6 and Color3.fromRGB(0,255,80)) or (hp > 0.3 and Color3.fromRGB(255,200,0)) or Color3.fromRGB(255,0,0)
            data.Health.From = Vector2.new(x-5, healthY)
            data.Health.To = Vector2.new(x-5, y+h)
            data.Health.Color = barColor
            data.Health.Visible = true
        end
    end
end

-- ==================== SPIN BOT ====================
local function startSpinBot()
    if SpinConnection then SpinConnection:Disconnect() end
    SpinConnection = RunService.RenderStepped:Connect(function()
        if not SpinBotEnabled then return end
        local character = LocalPlayer.Character
        if not character then return end
        local root = character:FindFirstChild("HumanoidRootPart")
        if root then
            local currentCFrame = root.CFrame
            local rotation = CFrame.Angles(0, math.rad(SpinSpeed), 0)
            root.CFrame = currentCFrame * rotation
        end
    end)
end

-- ==================== FOV CIRCLE ====================
local function updateFOVCircle()
    if FOVCircle then FOVCircle:Remove() end
    FOVCircle = Drawing.new("Circle")
    FOVCircle.Thickness = 2
    FOVCircle.NumSides = 64
    FOVCircle.Radius = FOVSize
    FOVCircle.Color = Color3.fromRGB(255, 50, 50)
    FOVCircle.Transparency = 0.8
    FOVCircle.Filled = false
    FOVCircle.Visible = true
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
end

-- ==================== AIMBOT LOGIC ====================
local function getClosestPlayer()
    local closest, shortest = nil, FOVSize
    local mousePos = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not isAlive(player) then continue end
        local aimPart = getAimPart(player.Character)
        if not aimPart then continue end
        local pos, onScreen = w2s(aimPart.Position)
        if not onScreen then continue end
        local dist = (mousePos - pos).Magnitude
        if dist < shortest then
            if WallCheckEnabled then
                local ray = Ray.new(Camera.CFrame.Position, (aimPart.Position - Camera.CFrame.Position).Unit * 1000)
                local hit = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character})
                if hit and not hit:IsDescendantOf(player.Character) then continue end
            end
            shortest = dist
            closest = player
        end
    end
    return closest
end

local function startAimbot()
    if AimbotConnection then AimbotConnection:Disconnect() end
    AimbotConnection = RunService.RenderStepped:Connect(function()
        if not AimbotEnabled and not AimbotLegitEnabled then return end
        local target = getClosestPlayer()
        if not target or not target.Character then return end
        local aimPart = getAimPart(target.Character)
        if not aimPart then return end
        local currentCFrame = Camera.CFrame
        local targetCFrame = CFrame.new(currentCFrame.Position, aimPart.Position)
        if AimbotLegitEnabled then
            Camera.CFrame = currentCFrame:Lerp(targetCFrame, LegitSmoothness)
        else
            Camera.CFrame = targetCFrame
        end
    end)
end

-- ==================== LOOP PRINCIPAL ====================
RunService.RenderStepped:Connect(function()
    if FOVCircle and ShowFOVEnabled then FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2) end
    if SkeletonEnabled then updateSkeleton() end
    if TracerEnabled then updateTracers() end
    if BoxESPEnabled then updateBoxESP() end
end)

